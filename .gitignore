# Environments
.venv/
env/
venv/

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# Security & Configurations
.env

# Data (Raw and Processed)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Machine Learning Artifacts
models/*.onnx
models/*.joblib
models/*.pkl
models/*.h5
!models/.gitkeep

# Logs
logs/*.log
!logs/.gitkeep

# Testing & Coverage
.coverage
.pytest_cache/
htmlcov/
nosetests.xml
coverage.xml
*,cover
